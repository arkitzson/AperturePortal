<Window x:Class="ApertureOS.ScanResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Review Found Games" Height="560" Width="560"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="HeaderText" Text="Review Found Games" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Content="&#xE8BB;" Style="{StaticResource TitleBarCloseButtonStyle}"
                        HorizontalAlignment="Right" Click="Cancel_Click"/>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,20,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="DescriptionText" Grid.Row="0" TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,12"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Select All" Height="28" Padding="10,0" FontSize="11" Click="SelectAll_Click"/>
                    <Button Content="Select None" Height="28" Padding="10,0" FontSize="11" Margin="8,0,0,0" Click="SelectNone_Click"/>
                </StackPanel>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,-16,0" Padding="0,0,16,0">
                    <ItemsControl x:Name="CandidatesItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Path}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="22,2,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Action buttons: a sibling of the ScrollViewer above, not inside it - same reasoning
                     as AddGameWindow's footer, guarantees Confirm/Cancel stay reachable however many
                     candidates a real scan turns up. -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Cancel" Width="96" Height="34" Margin="0,0,10,0" Click="Cancel_Click"/>
                    <Button x:Name="ConfirmButton" Content="Add Selected" Width="130" Height="34"
                            Style="{StaticResource AccentButtonStyle}" Click="Confirm_Click" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
