<Window x:Class="ApertureOS.AddGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Add Game" Height="700" Width="580"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="HeaderText" Text="Add Game" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Content="&#xE8BB;" Style="{StaticResource TitleBarCloseButtonStyle}"
                        HorizontalAlignment="Right" Click="Cancel_Click"/>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,20,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Scrollable form: the emulator panel (and Console row) added enough height that
                     the fixed-size window could clip the button row below entirely, with no way to
                     reach Save/Add - see the button row's own comment. Scrolling here instead of
                     just growing the window means it can't happen again no matter what gets added
                     to this form later. -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" Padding="0,0,10,0">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Game name -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" Margin="0,0,16,16">
                    <TextBlock Text="Game Name" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="NameTextBox" Margin="0,0,0,10"/>

                    <!-- Purely a badge/organization tag - doesn't change how the game launches or
                         how install state is tracked, so it's safe to set on any game regardless
                         of where its exe actually lives. Battle.net and Xbox games can't be
                         auto-detected (see SettingsWindow's Other Launchers section), so picking
                         the platform here is the only way they get the right tile badge. -->
                    <TextBlock Text="Platform" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="PlatformComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="PC / Other" Tag="Manual"/>
                        <ComboBoxItem Content="Steam" Tag="Steam"/>
                        <ComboBoxItem Content="Epic Games" Tag="Epic"/>
                        <ComboBoxItem Content="GOG" Tag="Gog"/>
                        <ComboBoxItem Content="Battle.net" Tag="BattleNet"/>
                        <ComboBoxItem Content="Xbox" Tag="Xbox"/>
                    </ComboBox>

                    <!-- The originating console (e.g. "PlayStation 5") - separate from Platform
                         above, which is the launcher/sync source, not where the game actually
                         released. Typed by hand - no external metadata API drives this. -->
                    <TextBlock Text="Console (optional)" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,10,0,6"/>
                    <TextBox x:Name="ConsoleTextBox"/>
                </StackPanel>

                <!-- Exe path -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Margin="0,0,16,16">
                    <TextBlock x:Name="ExePathLabel" Text="Game Executable" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <DockPanel>
                        <Button Content="Browse..." MinWidth="84" DockPanel.Dock="Right" Click="BrowseExe_Click"/>
                        <TextBox x:Name="ExePathTextBox" Margin="0,0,8,0" IsReadOnly="True"/>
                    </DockPanel>

                    <CheckBox x:Name="IsEmulatedCheckBox" Content="Launch through an emulator"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,10,0,0"
                              Checked="IsEmulatedCheckBox_CheckedChanged" Unchecked="IsEmulatedCheckBox_CheckedChanged"/>

                    <!-- The emulator's own exe - what actually gets launched when IsEmulated is set.
                         The game file above (relabeled "Game File" while this is checked) is passed
                         to it as a launch argument instead of being run directly. -->
                    <StackPanel x:Name="EmulatorPanel" Visibility="Collapsed" Margin="0,10,0,0">
                        <TextBlock Text="Emulator Executable" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <DockPanel>
                            <Button Content="Browse..." MinWidth="84" DockPanel.Dock="Right" Click="BrowseEmulator_Click"/>
                            <TextBox x:Name="EmulatorPathTextBox" Margin="0,0,8,0" IsReadOnly="True"/>
                        </DockPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Cover image path -->
                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical" Margin="0,0,16,16">
                    <TextBlock Text="Cover Image (600x900 recommended)" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <DockPanel>
                        <Button Content="Browse..." MinWidth="84" DockPanel.Dock="Right" Click="BrowseImage_Click"/>
                        <Button Content="Find Art..." MinWidth="84" DockPanel.Dock="Right" Margin="0,0,8,0" Click="FindCoverArt_Click"/>
                        <TextBox x:Name="ImagePathTextBox" Margin="0,0,8,0" IsReadOnly="True"/>
                    </DockPanel>
                </StackPanel>

                <!-- Cover preview -->
                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Width="150" Height="225"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                        VerticalAlignment="Top" ClipToBounds="True">
                    <Image x:Name="CoverPreviewImage" Stretch="UniformToFill"/>
                </Border>

                <!-- Header image path -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,0,0,10">
                    <TextBlock Text="Header Image (1920x620 recommended, optional)" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <DockPanel>
                        <Button Content="Browse..." MinWidth="84" DockPanel.Dock="Right" Click="BrowseHeaderImage_Click"/>
                        <Button Content="Find Art..." MinWidth="84" DockPanel.Dock="Right" Margin="0,0,8,0" Click="FindHeaderArt_Click"/>
                        <TextBox x:Name="HeaderImagePathTextBox" Margin="0,0,8,0" IsReadOnly="True"/>
                    </DockPanel>
                </StackPanel>

                <!-- Header preview -->
                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Height="130"
                        Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}"
                        ClipToBounds="True">
                    <Image x:Name="HeaderPreviewImage" Stretch="UniformToFill"/>
                </Border>

                </Grid>
                </ScrollViewer>

                <!-- Action buttons: a sibling of the ScrollViewer above (Auto height), not inside
                     it - pinned to the bottom of the window so it's always reachable regardless of
                     how tall the scrollable form content gets. -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="96" Height="34" Margin="0,0,10,0" Click="Cancel_Click"/>
                    <Button x:Name="SaveButton" Content="Add Game" Width="110" Height="34" Style="{StaticResource AccentButtonStyle}"
                            Click="Add_Click" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
