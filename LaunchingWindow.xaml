<Window x:Class="ApertureOS.LaunchingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Aperture Portal - Launching"
        WindowStyle="None"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowState="Maximized"
        WindowStartupLocation="Manual">
    <Grid>
        <!-- Full-bleed blurred backdrop, same treatment as the pause overlay: source/blur amount
             are set in code-behind (SetGame) since the header image only needs a light blur but the
             cover art fallback needs a much heavier one to hide the stretch distortion. Deliberately
             not Topmost - once the real game window appears it should just naturally draw over this,
             no z-order fight needed, since nothing was competing for foreground when this was shown. -->
        <Grid ClipToBounds="True">
            <Image x:Name="BackdropImage" Stretch="UniformToFill">
                <Image.Effect>
                    <BlurEffect x:Name="BackdropBlur" Radius="55"/>
                </Image.Effect>
            </Image>
            <Border Background="#CC121016"/>
        </Grid>

        <!-- Launching card -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="300" Height="420" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="18" Margin="0,0,0,28">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55" BlurRadius="35" ShadowDepth="8"/>
                </Border.Effect>
                <Border Background="{StaticResource SurfaceBrush}">
                    <Border.Clip>
                        <RectangleGeometry Rect="0,0,300,420" RadiusX="18" RadiusY="18"/>
                    </Border.Clip>
                    <Image x:Name="CoverImage" Stretch="UniformToFill"/>
                </Border>
            </Border>

            <TextBlock x:Name="GameNameText" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="480"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
            <TextBlock x:Name="StartingText" Text="Starting..." FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.35" Duration="0:0:0.9"
                                                 AutoReverse="True" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
