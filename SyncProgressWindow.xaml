<Window x:Class="ApertureOS.SyncProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Syncing Your Library" Height="176" Width="420"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- No close button - this is non-interactive by design while a sync is in progress. -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}">
                <TextBlock Text="Syncing Your Library" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,20,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="StatusText" Grid.Row="0" Text="Installing your games and fetching art..."
                           FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,14"/>

                <ProgressBar x:Name="ProgressIndicator" Grid.Row="1" Height="8" IsIndeterminate="True"/>

                <TextBlock x:Name="ProgressCountText" Grid.Row="2" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Grid>
    </Border>
</Window>
