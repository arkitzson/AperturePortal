<Window x:Class="ApertureOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:ApertureOS"
        mc:Ignorable="d"
        Title="Aperture Portal" Height="640" Width="960" MinWidth="720" MinHeight="480"
        Icon="Assets/AppIcon.ico"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="Assets/Logo.png" Width="18" Height="18" VerticalAlignment="Center"/>
                    <TextBlock Text="Aperture Portal" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="UpdateAvailableButton" Style="{StaticResource AccentButtonStyle}"
                            Height="24" Padding="10,0" FontSize="11" VerticalAlignment="Center"
                            Margin="0,0,10,0" Visibility="Collapsed" Click="UpdateAvailableButton_Click"/>
                    <Button x:Name="SettingsButton" Content="&#xE713;" Style="{StaticResource TitleBarButtonStyle}"
                            Click="SettingsButton_Click"/>
                    <Button x:Name="MinimizeButton" Content="&#xE921;" Style="{StaticResource TitleBarButtonStyle}"
                            Click="Minimize_Click"/>
                    <Button x:Name="MaximizeRestoreButton" Content="&#xE922;" Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestore_Click"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,20,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="My Games" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Items.Count, ElementName=GamesItemsControl, StringFormat='{}{0} games in your library'}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ConsoleModeButton" Content="Console Mode" Width="140" Height="34"
                                Margin="0,0,10,0" Click="ConsoleModeButton_Click"/>
                        <Button x:Name="AddGameButton" Content="+ Add Game" Width="130" Height="34"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="AddGameButton_Click"/>
                    </StackPanel>
                </DockPanel>

                <DockPanel Grid.Row="1" Margin="0,0,0,16">
                    <Grid DockPanel.Dock="Right" Width="220" Height="34">
                        <TextBox x:Name="SearchBox" VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged"
                                 GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="Search games..." Margin="9,0,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="FilterInstalledButton" Content="Installed" Tag="Installed" GroupName="LibraryFilter"
                                     Style="{StaticResource FilterTabStyle}" Checked="FilterTab_Checked"/>
                        <RadioButton x:Name="FilterRecentButton" Content="Recently Played" Tag="RecentlyPlayed" GroupName="LibraryFilter"
                                     Style="{StaticResource FilterTabStyle}" Margin="8,0,0,0" Checked="FilterTab_Checked"/>
                        <!-- No IsChecked="True" here: which tab starts checked depends on the saved
                             LastLibraryFilter setting, so MainWindow() sets it explicitly once
                             InitializeComponent() has finished (see SyncFilterTabToSetting). -->
                        <RadioButton x:Name="FilterAllButton" Content="All" Tag="All" GroupName="LibraryFilter"
                                     Style="{StaticResource FilterTabStyle}" Margin="8,0,0,0" Checked="FilterTab_Checked"/>
                        <RadioButton x:Name="FilterNotInstalledButton" Content="Not Installed" Tag="NotInstalled" GroupName="LibraryFilter"
                                     Style="{StaticResource FilterTabStyle}" Margin="8,0,0,0" Checked="FilterTab_Checked"/>
                    </StackPanel>
                </DockPanel>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="GamesItemsControl" Padding="16,16,16,24" HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Panel.ZIndex" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Panel.ZIndex" Value="10"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="160" Margin="0,0,16,16">
                                    <Button Tag="{Binding}" Click="GameTile_Click" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0" Padding="0"
                                            FocusVisualStyle="{x:Null}"
                                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="TileRoot" Width="160" Height="276"
                                                        Background="Transparent"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform x:Name="TileScale" ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <Border.Effect>
                                                        <DropShadowEffect x:Name="TileShadow" Color="#000000" Opacity="0.35"
                                                                          BlurRadius="8" ShadowDepth="2"/>
                                                    </Border.Effect>

                                                    <!-- Rounded, clipped card content lives on its own inner Border so the
                                                         outer Border's Effect (shadow) never gets truncated by the Clip. -->
                                                    <Border Width="160" Height="276" Background="{StaticResource SurfaceBrush}">
                                                        <Border.Clip>
                                                            <RectangleGeometry Rect="0,0,160,276" RadiusX="10" RadiusY="10"/>
                                                        </Border.Clip>
                                                        <StackPanel>
                                                            <Grid Width="160" Height="240" ClipToBounds="True">
                                                                <Image Source="{Binding CoverImagePath}" Width="160" Height="240" Stretch="UniformToFill">
                                                                    <Image.Effect>
                                                                        <BlurEffect x:Name="CoverBlur" Radius="0"/>
                                                                    </Image.Effect>
                                                                </Image>
                                                                <Border x:Name="Scrim" Background="#99000000" Opacity="0"/>

                                                                <!-- Steam is this app's implicit default and Manual has no platform to
                                                                     show, so Game.ShowPlatformBadge only turns this on for the less-common
                                                                     platforms (Epic/GOG/Battle.net/Xbox) - keeps the common case quiet. -->
                                                                <Border Background="#CC000000" CornerRadius="4" Panel.ZIndex="5"
                                                                        Padding="5,2" Margin="6,6,0,0"
                                                                        HorizontalAlignment="Left" VerticalAlignment="Top"
                                                                        Visibility="{Binding ShowPlatformBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <TextBlock Text="{Binding PlatformBadgeText}" FontSize="9" FontWeight="Bold"
                                                                               Foreground="White"/>
                                                                </Border>

                                                                <Border x:Name="PlayBadge" Width="52" Height="52" CornerRadius="26"
                                                                        Background="{StaticResource AccentBrush}" Opacity="0"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Path Data="M 0,0 L 0,20 L 17,10 Z" Fill="White"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                          Margin="4,0,0,0"/>
                                                                </Border>

                                                                <!-- Not-yet-installed Steam games: a small persistent badge (not
                                                                     hidden behind hover, unlike PlayBadge) so the cover art itself
                                                                     stays fully visible. Shows a download icon while idle, or
                                                                     "Installing" once a download starts, plus an indeterminate
                                                                     loading strip along the bottom edge of the art - Steam doesn't
                                                                     expose a reliable ETA/speed, so a real percentage reads as more
                                                                     precise than it actually is; a loading effect doesn't overpromise. -->
                                                                <Border x:Name="InstallBadge" Width="52" Height="52" CornerRadius="26"
                                                                        Background="#CC000000" Panel.ZIndex="5"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Visibility="{Binding ShowInstallOverlay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <Grid>
                                                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Visibility="{Binding ShowInstallIcon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                        <TextBlock Text="Installing" FontSize="10"
                                                                                   FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   TextAlignment="Center" TextWrapping="Wrap"
                                                                                   Visibility="{Binding ShowDownloadProgress, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                    </Grid>
                                                                </Border>
                                                                <Border Height="5" VerticalAlignment="Bottom" Background="#33FFFFFF" Panel.ZIndex="5"
                                                                        ClipToBounds="True"
                                                                        Visibility="{Binding ShowDownloadProgress, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <Border Width="60" Height="5" Background="{StaticResource AccentBrush}" HorizontalAlignment="Left">
                                                                        <Border.RenderTransform>
                                                                            <TranslateTransform x:Name="LoadingBarTranslate" X="-60"/>
                                                                        </Border.RenderTransform>
                                                                        <Border.Triggers>
                                                                            <EventTrigger RoutedEvent="Loaded">
                                                                                <BeginStoryboard>
                                                                                    <Storyboard RepeatBehavior="Forever">
                                                                                        <DoubleAnimation Storyboard.TargetName="LoadingBarTranslate" Storyboard.TargetProperty="X"
                                                                                                         From="-60" To="160" Duration="0:0:1.1"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </EventTrigger>
                                                                        </Border.Triggers>
                                                                    </Border>
                                                                </Border>

                                                                <Button x:Name="MoreButton" Tag="{Binding}"
                                                                        Width="28" Height="28" Padding="0" Opacity="0"
                                                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                        Margin="0,6,6,0" Background="#99000000"
                                                                        BorderThickness="0" Cursor="Hand"
                                                                        FocusVisualStyle="{x:Null}"
                                                                        Focusable="False"
                                                                        Click="MoreButton_Click">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="MoreChrome" Background="{TemplateBinding Background}" CornerRadius="14">
                                                                                <TextBlock Text="&#x22EF;" FontSize="16" FontWeight="Bold"
                                                                                           Foreground="White" HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="MoreChrome" Property="Background" Value="#CC000000"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                    <Button.ContextMenu>
                                                                        <ContextMenu Placement="Bottom">
                                                                            <MenuItem Header="Edit Game" Click="EditGame_Click"/>
                                                                            <MenuItem Header="Delete Game" Click="DeleteGame_Click"/>
                                                                        </ContextMenu>
                                                                    </Button.ContextMenu>
                                                                </Button>
                                                            </Grid>
                                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                                                       FontWeight="SemiBold" HorizontalAlignment="Center" Margin="6,8,6,10"
                                                                       TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Border>

                                                <ControlTemplate.Resources>
                                                    <Storyboard x:Key="TileActivateStoryboard">
                                                        <DoubleAnimation Storyboard.TargetName="TileScale" Storyboard.TargetProperty="ScaleX"
                                                                         To="1.04" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="TileScale" Storyboard.TargetProperty="ScaleY"
                                                                         To="1.04" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="TileShadow" Storyboard.TargetProperty="BlurRadius"
                                                                         To="18" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="TileShadow" Storyboard.TargetProperty="Opacity"
                                                                         To="0.6" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="CoverBlur" Storyboard.TargetProperty="Radius"
                                                                         To="6" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="Scrim" Storyboard.TargetProperty="Opacity"
                                                                         To="1" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="PlayBadge" Storyboard.TargetProperty="Opacity"
                                                                         To="1" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="MoreButton" Storyboard.TargetProperty="Opacity"
                                                                         To="1" Duration="0:0:0.12"/>
                                                    </Storyboard>
                                                    <Storyboard x:Key="TileDeactivateStoryboard">
                                                        <DoubleAnimation Storyboard.TargetName="TileScale" Storyboard.TargetProperty="ScaleX"
                                                                         To="1" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="TileScale" Storyboard.TargetProperty="ScaleY"
                                                                         To="1" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="TileShadow" Storyboard.TargetProperty="BlurRadius"
                                                                         To="8" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="TileShadow" Storyboard.TargetProperty="Opacity"
                                                                         To="0.35" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="CoverBlur" Storyboard.TargetProperty="Radius"
                                                                         To="0" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="Scrim" Storyboard.TargetProperty="Opacity"
                                                                         To="0" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="PlayBadge" Storyboard.TargetProperty="Opacity"
                                                                         To="0" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="MoreButton" Storyboard.TargetProperty="Opacity"
                                                                         To="0" Duration="0:0:0.12"/>
                                                    </Storyboard>
                                                </ControlTemplate.Resources>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard Storyboard="{StaticResource TileActivateStoryboard}"/>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard Storyboard="{StaticResource TileDeactivateStoryboard}"/>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard Storyboard="{StaticResource TileActivateStoryboard}"/>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard Storyboard="{StaticResource TileDeactivateStoryboard}"/>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
