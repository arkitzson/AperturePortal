<Window x:Class="ApertureOS.ManageCategoriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Categories" Height="640" Width="860"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="CategoryListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome" Background="{StaticResource SurfaceBrush}"
                                BorderThickness="2" BorderBrush="Transparent" CornerRadius="8">
                            <ContentPresenter Margin="12,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <DataTemplate x:Key="GameCheckRowTemplate">
            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsInCategory, Mode=TwoWay}"
                       Foreground="{StaticResource TextPrimaryBrush}" Padding="8,0,0,0" Margin="0,0,0,10"/>
        </DataTemplate>

        <!-- Auto categories' membership is derived, not user-editable - a plain name instead of a
             checkbox is what actually tells them apart from the custom-category list at a glance. -->
        <DataTemplate x:Key="GameNameRowTemplate">
            <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimaryBrush}" Padding="8,0,0,0" Margin="0,0,0,10"/>
        </DataTemplate>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Categories" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Content="&#xE8BB;" Style="{StaticResource TitleBarCloseButtonStyle}"
                        HorizontalAlignment="Right" Click="Close_Click"/>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,20,24,20">
                <!-- Row 0 (header) and Row 1 (content) are shared across both columns rather than
                     each column getting its own independent split - that's what makes the left and
                     right empty states land at the same vertical center. Row 0 is sized by the left
                     header alone (column 2 has nothing in it), but both columns' content then center
                     within the exact same Row 1 band regardless. -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: reorderable category list -->
                <DockPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                    <Button Content="+ New Category" DockPanel.Dock="Right" Height="34" Padding="14,0"
                            Style="{StaticResource AccentButtonStyle}" Click="NewCategory_Click"/>
                    <TextBlock Text="Use the arrows below to reorder - that controls what comes first in your library."
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,12,0"/>
                </DockPanel>

                <Grid Grid.Row="1" Grid.Column="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox x:Name="CategoriesListBox" Background="Transparent" BorderThickness="0"
                                     ItemContainerStyle="{StaticResource CategoryListBoxItemStyle}"
                                     SelectionChanged="CategoriesListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <Border Background="#CC000000" CornerRadius="4" Padding="5,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding KindLabel}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding GameCountLabel}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,10"/>

                                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                <Button Content="&#x25B2;" Style="{StaticResource SmallIconButtonStyle}"
                                                        Click="MoveUp_Click" Tag="{Binding}" Margin="0,0,4,0"/>
                                                <Button Content="&#x25BC;" Style="{StaticResource SmallIconButtonStyle}"
                                                        Click="MoveDown_Click" Tag="{Binding}" Margin="0,0,10,0"/>
                                                <Button Content="Rename" Height="28" Padding="8,0" FontSize="11"
                                                        Click="Rename_Click" Tag="{Binding}" Margin="0,0,4,0"/>
                                                <Button Content="Delete" Height="28" Padding="8,0" FontSize="11"
                                                        IsEnabled="{Binding IsCustom}" Click="Delete_Click" Tag="{Binding}"
                                                        ToolTip="{Binding DeleteLockedTooltip}" ToolTipService.ShowOnDisabled="True"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                        <!-- Shown instead of the (otherwise empty) list itself - a fresh library has
                             no auto categories yet and may have no custom ones either. -->
                        <StackPanel x:Name="CategoriesEmptyState" Visibility="Collapsed"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="300">
                            <TextBlock Text="&#x1F3F7;&#xFE0F;" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="No categories yet" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                            <TextBlock Text="Console and platform categories appear automatically as you add games, or create your own above."
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                </Grid>

                <!-- Right: shows the selected category's games - checkable for a custom category
                     (assignment is user-editable), read-only for an auto one (membership is derived).
                     Row 1 only (not RowSpan="2") - same reasoning as the left column above, so
                     AssignmentPlaceholder centers against the same band CategoriesEmptyState does. -->
                <Grid Grid.Row="1" Grid.Column="2">
                    <StackPanel x:Name="AssignmentPlaceholder"
                                HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="320">
                        <TextBlock Text="&#x1F3AE;" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a category" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                        <TextBlock Text="Pick a custom category on the left to choose which games belong to it, or an auto category to see what's in it."
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Grid x:Name="AssignmentContent" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="AssignmentHeaderText" Grid.Row="0"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="GamesItemsControl"/>
                            </ScrollViewer>

                            <TextBlock x:Name="NoGamesInLibraryText" Visibility="Collapsed"
                                       Text="Add some games first, then come back here to organize them."
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="280"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
