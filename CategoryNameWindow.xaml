<Window x:Class="ApertureOS.CategoryNameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="New Category" Height="176" Width="380"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="HeaderText" Text="New Category" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Content="&#xE8BB;" Style="{StaticResource TitleBarCloseButtonStyle}"
                        HorizontalAlignment="Right" Click="Cancel_Click"/>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Category Name" FontWeight="SemiBold" Grid.Row="0"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="NameTextBox" Grid.Row="1" VerticalAlignment="Top"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Cancel" Width="96" Height="34" Margin="0,0,10,0" Click="Cancel_Click"/>
                    <Button x:Name="OkButton" Content="OK" Width="96" Height="34"
                            Style="{StaticResource AccentButtonStyle}" Click="Ok_Click" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
