<Window x:Class="ApertureOS.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Aperture Portal Overlay"
        WindowStyle="None"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowState="Maximized"
        WindowStartupLocation="Manual">
    <Grid>
        <!-- Full-bleed blurred backdrop of the game's own art, darkened so foreground text/buttons stay readable.
             Source/blur amount are set in code-behind (SetGame): the header image gets a light blur since it's
             already the right aspect ratio, while the cover art fallback needs the heavier blur to hide how much
             a portrait image distorts when stretched to fill a landscape screen. -->
        <Grid ClipToBounds="True">
            <Image x:Name="BackdropImage" Stretch="UniformToFill">
                <Image.Effect>
                    <BlurEffect x:Name="BackdropBlur" Radius="55"/>
                </Image.Effect>
            </Image>
            <Border Background="#CC121016"/>
        </Grid>

        <!-- Suspend menu -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="300" Height="420" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="18" Margin="0,0,0,28">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55" BlurRadius="35" ShadowDepth="8"/>
                </Border.Effect>
                <Border Background="{StaticResource SurfaceBrush}">
                    <Border.Clip>
                        <RectangleGeometry Rect="0,0,300,420" RadiusX="18" RadiusY="18"/>
                    </Border.Clip>
                    <Image Source="{Binding CoverImagePath}" Stretch="UniformToFill"/>
                </Border>
            </Border>

            <TextBlock Text="{Binding Name}" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="480"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
            <TextBlock Text="Paused" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,32"/>

            <Button x:Name="ResumeButton" Content="Resume Game" Width="280" Height="48" Margin="0,0,0,12"
                    Style="{StaticResource AccentButtonStyle}" FontSize="15"
                    Click="ResumeButton_Click"/>
            <Button x:Name="ExitGameButton" Content="Exit Game" Width="280" Height="48" Margin="0,0,0,12"
                    FontSize="15" Click="ExitGameButton_Click"/>
            <Button x:Name="SleepButton" Content="Sleep" Width="280" Height="48"
                    FontSize="15" Click="SleepButton_Click"/>

            <TextBlock Text="D-Pad to navigate • A to confirm • Ctrl+P or Back+Start to resume" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,28,0,0"/>
        </StackPanel>
    </Grid>
</Window>
