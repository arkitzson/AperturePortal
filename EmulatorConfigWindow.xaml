<Window x:Class="ApertureOS.EmulatorConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Add Emulator" Height="440" Width="460"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="HeaderText" Text="Add Emulator" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Content="&#xE8BB;" Style="{StaticResource TitleBarCloseButtonStyle}"
                        HorizontalAlignment="Right" Click="Cancel_Click"/>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Scrollable form + pinned footer, same fix already applied to AddGameWindow -
                     a fixed-height window with no ScrollViewer let the footer get squeezed off the
                     bottom entirely (buttons rendered as unreadable slivers) once every field had
                     real values in it. -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Name" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="NameTextBox" Margin="0,0,0,14"/>

                    <TextBlock Text="Emulator Executable" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <DockPanel Margin="0,0,0,14">
                        <Button Content="Browse..." MinWidth="84" DockPanel.Dock="Right" Click="BrowseEmulator_Click"/>
                        <TextBox x:Name="EmulatorPathTextBox" Margin="0,0,8,0" IsReadOnly="True"/>
                    </DockPanel>

                    <TextBlock Text="ROM Folder" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <DockPanel Margin="0,0,0,14">
                        <Button Content="Browse..." MinWidth="84" DockPanel.Dock="Right" Click="BrowseRomFolder_Click"/>
                        <TextBox x:Name="RomFolderTextBox" Margin="0,0,8,0" IsReadOnly="True"/>
                    </DockPanel>

                    <TextBlock Text="Console" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="ConsoleTextBox"/>
                    <TextBlock Text="e.g. &quot;Nintendo Switch&quot; - every ROM found in this folder gets tagged with this console automatically."
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="96" Height="34" Margin="0,0,10,0" Click="Cancel_Click"/>
                    <Button x:Name="OkButton" Content="Save" Width="96" Height="34"
                            Style="{StaticResource AccentButtonStyle}" Click="Ok_Click" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
